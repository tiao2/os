<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/dark_bg">

    <EditText
        android:id="@+id/et_waveform_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/waveform_name_hint"
        android:textColor="@android:color/white"
        android:textColorHint="#AAAAAA"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/fundamental_amp"
        android:layout_marginTop="12dp"
        android:textColor="#FFFFFF"/>

    <SeekBar
        android:id="@+id/sb_fundamental_amp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="80"/>

    <TextView
        android:id="@+id/tv_fundamental_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:text="80%"
        android:textColor="#FFFFFF"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/harmonics"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <LinearLayout
            android:id="@+id/ll_harmonics_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btn_add_harmonic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/add_harmonic"
            android:layout_marginTop="12dp"
            style="@style/OutlinedButton"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp">

        <Button
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="@string/cancel"
            style="@style/TextButton"/>

        <Button
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="@string/save"
            android:layout_marginStart="8dp"
            style="@style/PrimaryButton"/>
    </LinearLayout>
</LinearLayout>
